# Keep the Docker build context small. Everything listed here is excluded
# from the tarball sent to the daemon — Rust artefacts, JS deps, IDE state,
# docs, and any local build output. These are all reproducible inside the
# image, so shipping them from the host would just bloat the context.

# Node / JS
node_modules/
**/node_modules/
**/.next/
**/.turbo/
**/dist/
**/build/
*.log

# Rust (vigil-agent, vigil-tray) — not part of the Hub image
target/
**/target/

# VCS + tooling
.git/
.gitignore
.github/

# Editors / IDEs
.vscode/
.idea/

# Env files — never bake these into the image
.env
.env.*
!.env.example

# Local artefacts
*.log
*.tmp
.DS_Store
