# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
POSTGRES_DB=vigil
POSTGRES_USER=vigil
POSTGRES_PASSWORD=          # Strong password for PostgreSQL
DATABASE_URL="postgresql://vigil:PASSWORD@localhost:5432/vigil?schema=public"

# ── Encryption ────────────────────────────────────────────────
# 32-byte key as 64 hex chars. Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Authentication ────────────────────────────────────────────
# Secret for Better Auth sessions. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Application URL ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Azure AD / Microsoft SSO (optional) ─────────────────────
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# ── Google SSO (optional) ───────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── SMTP Email Alerts (optional) ────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=vigil@example.com

# ── Twilio SMS Alerts (optional) ────────────────────────────
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=+1234567890

# ── Agent Binaries ──────────────────────────────────────────
# Path to store agent binary releases for auto-update
AGENT_BINARIES_PATH=./binaries
