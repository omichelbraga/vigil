generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Better Auth tables ──────────────────────────────────

model user {
  id                 String    @id
  name               String
  email              String    @unique
  emailVerified      Boolean   @default(false) @map("email_verified")
  image              String?
  role               String    @default("viewer") // admin, editor, viewer
  twoFactorEnabled   Boolean   @default(false) @map("two_factor_enabled")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  sessions      session[]
  accounts      account[]
  twoFactor     twoFactor[]
  auditLogs     AuditLog[]

  @@map("users")
}

model session {
  id        String   @id
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model account {
  id                    String    @id
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

model twoFactor {
  id        String @id
  userId    String @map("user_id")
  secret    String
  backupCodes String @map("backup_codes")

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factors")
}

// ── Application models ──────────────────────────────────

model Agent {
  id            String   @id @default(uuid())
  name          String   @unique
  tokenHash     String   @map("token_hash") // argon2 hash — never plaintext
  lastSeen      DateTime? @map("last_seen")
  version       String?
  os            String?
  hostname      String?
  ipAddress     String?  @map("ip_address")
  status        String   @default("active")
  enrolledAt    DateTime? @map("enrolled_at")
  isActive      Boolean  @default(true) @map("is_active")
  autoUpdate    Boolean  @default(false) @map("auto_update")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  checks       Check[]
  checkResults CheckResult[]

  @@map("agents")
}

model Check {
  id           String   @id @default(uuid())
  agentId      String   @map("agent_id")
  name         String
  type         String   // service, port, http, ping, cert, process, resource
  config       Json     // monitor-specific configuration
  enabled      Boolean  @default(true)
  intervalSecs Int      @default(30) @map("interval_secs")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  agent   Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  results CheckResult[]

  @@map("checks")
}

model CheckResult {
  id             String   @id @default(uuid())
  checkId        String   @map("check_id")
  agentId        String   @map("agent_id")
  status         String   // ok, warning, critical, unknown
  message        String?
  responseTimeMs Int?     @map("response_time_ms")
  metadata       Json?
  timestamp      DateTime @default(now())

  check Check @relation(fields: [checkId], references: [id], onDelete: Cascade)
  agent Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([checkId, timestamp])
  @@index([agentId, timestamp])
  @@map("check_results")
}

model AlertChannel {
  id        String   @id @default(uuid())
  name      String
  type      String   // email, slack, webhook, pagerduty, teams, discord, telegram, twilio, generic
  config    Json     // channel-specific config (urls, tokens, etc.) — encrypted values
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rules AlertRule[]

  @@map("alert_channels")
}

model AlertRule {
  id             String   @id @default(uuid())
  name           String
  channelId      String   @map("channel_id")
  condition      Json     // e.g. { "status": "critical", "consecutiveCount": 3 }
  enabled        Boolean  @default(true)
  cooldownMinutes Int     @default(15) @map("cooldown_minutes")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  channel  AlertChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  history  AlertHistory[]

  @@map("alert_rules")
}

model AlertHistory {
  id        String   @id @default(uuid())
  ruleId    String   @map("rule_id")
  checkId   String?  @map("check_id")
  agentId   String?  @map("agent_id")
  status    String   // fired, resolved, acknowledged
  message   String?
  channel   String?  // channel type used
  delivered Boolean  @default(false)
  firedAt   DateTime @default(now()) @map("fired_at")
  resolvedAt DateTime? @map("resolved_at")

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, firedAt])
  @@index([checkId, firedAt])
  @@map("alert_history")
}

model BrandingConfig {
  id          String   @id @default(uuid())
  companyName String?  @map("company_name")
  logoUrl     String?  @map("logo_url")
  primaryColor String? @map("primary_color")
  faviconUrl  String?  @map("favicon_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("branding_config")
}

model CertMonitor {
  id          String   @id @default(uuid())
  host        String
  port        Int      @default(443)
  warnDays    Int      @default(30) @map("warn_days")
  enabled     Boolean  @default(true)
  lastChecked DateTime? @map("last_checked")
  expiresAt   DateTime? @map("expires_at")
  issuer      String?
  status      String?  // valid, expiring, expired, error
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("cert_monitors")
}

model AzureKeyVaultConfig {
  id           String   @id @default(uuid())
  name         String
  vaultUrl     String   @map("vault_url")
  tenantId     String   @map("tenant_id")
  clientId     String   @map("client_id")
  clientSecret String   @map("client_secret") // encrypted at rest
  enabled      Boolean  @default(true)
  lastSynced   DateTime? @map("last_synced")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("azure_keyvault_configs")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  resource  String
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user user? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model AgentRelease {
  id        String   @id @default(cuid())
  os        String   // linux, windows
  arch      String   // amd64, arm64
  version   String
  sha256    String
  filename  String
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("agent_releases")
}

model SmtpConfig {
  id        String   @id @default(uuid())
  host      String
  port      Int      @default(587)
  secure    Boolean  @default(false)
  user      String?
  pass      String?  // encrypted at rest
  fromEmail String   @map("from_email")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("smtp_config")
}

model AppConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("app_config")
}

model EnrollmentToken {
  id        String    @id @default(uuid())
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  agentId   String?   @map("agent_id")
  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  @@map("enrollment_tokens")
}
